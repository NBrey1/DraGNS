; Energy minimization for NH3 solid (OPLS-AA)
integrator  = steep
emtol       = 100.0
emstep      = 0.001
nsteps      = 5000

cutoff-scheme = Verlet
nstlist       = 10
pbc           = xyz

coulombtype   = PME
rcoulomb      = 1.0

vdwtype       = Cut-off
rvdw          = 1.0
DispCorr      = EnerPres

constraints   = none
