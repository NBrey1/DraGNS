&GLOBAL
      PROJECT Titan_Ice_D2O_Quantum
      RUN_TYPE MD
      PRINT_LEVEL LOW
    &END GLOBAL

    &FORCE_EVAL
      METHOD Quickstep
      &DFT
        &QS
          METHOD PM6
          EPS_DEFAULT 1.0E-10
        &END QS
        &SCF
          MAX_SCF 40                  
          EPS_SCF 1.0E-5  ! Optimized for faster step calculation
          IGNORE_CONVERGENCE_FAILURE .TRUE.
          &OT
            MINIMIZER DIIS
            PRECONDITIONER FULL_SINGLE_INVERSE
          &END OT
        &END SCF
      &END DFT

      &SUBSYS
        &CELL
          ABC 9.036 9.036 14.712
          ALPHA_BETA_GAMMA 90 90 120
          PERIODIC XYZ
        &END CELL
        &TOPOLOGY
          COORD_FILE_NAME ice_d20relaxed.xyz
          COORD_FILE_FORMAT XYZ
        &END TOPOLOGY

        &KIND H
          ELEMENT H
          MASS 2.014102   ! Heavy water
        &END KIND
      &END SUBSYS
    &END FORCE_EVAL

    &MOTION
      &MD
        ENSEMBLE NVE  
        STEPS 1000    ! 1000 steps at 1.0 fs = 1 picosecond total
        TIMESTEP 1.0  
        TEMPERATURE 94.0
      &END MD
      &PRINT
        &TRAJECTORY
          &EACH
            MD 1  
          &END EACH
        &END TRAJECTORY
        &VELOCITIES   
          &EACH
            MD 1
          &END EACH
        &END VELOCITIES
      &END PRINT
    &END MOTION
    